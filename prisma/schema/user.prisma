model User {
  id       String @id @default(uuid())
  name     String @db.VarChar(255)
  email    String @unique @db.VarChar(255)
  password String
  phone    String
  role     Role   @default(CUSTOMER)
  status   Status @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items    Item[]
  orders   Order[]
  payments Payment[]
  reviews  Review[]

  @@map("users")
}
